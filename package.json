{
  "name": "bdsm-tools",
  "version": "1.5.2",
  "description": "BDSM Tools Web Application",
  "main": "index.js",
  "scripts": {
    "start": "webpack serve --config webpack-local.config.js --progress --bail",
    "build": "webpack --config webpack-prod.config.js --bail && npm run update-version",
    "test-build": "webpack --config webpack-dev.config.js --bail && npm run update-version",
    "test": "npm run lint && npm run test-compile",
    "test-compile": "webpack --config webpack-common.config.js --bail --mode development",
    "lint:fix": "npm run lint -- --fix",
    "update-version": "generate-version -s package -b dist",
    "lint": "jshint src/ && eslint './**/*.{js,jsx}'",
    "format": "prettier . --write"
  },
  "author": "keepsafemaster",
  "license": "ISC",
